<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#0a0a0f"
    android:gravity="center"
    tools:context=".MainActivity">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_launcher"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VORTEX RAT"
        android:textSize="28sp"
        android:textColor="#ff0040"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_marginBottom="5dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Broken but Limitless"
        android:textSize="14sp"
        android:textColor="#666"
        android:fontFamily="monospace"
        android:layout_marginBottom="30dp" />

    <Button
        android:id="@+id/btnAccessibility"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Enable Accessibility"
        android:textColor="#fff"
        android:background="#ff0040"
        android:fontFamily="monospace"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btnDeviceAdmin"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Enable Device Admin"
        android:textColor="#fff"
        android:background="#cc0033"
        android:fontFamily="monospace"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btnBatteryOptimization"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Disable Battery Optimization"
        android:textColor="#fff"
        android:background="#990033"
        android:fontFamily="monospace" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0"
        android:textSize="12sp"
        android:textColor="#333"
        android:fontFamily="monospace"
        android:layout_marginTop="30dp" />

</LinearLayout>